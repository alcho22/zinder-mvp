generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum RequestStatus {
  DRAFT
  SUBMITTED
  QUOTED
  BOOKED
  COMPLETED
  CANCELLED
}

enum QuoteStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

model User {
  id              String           @id @default(cuid())
  fullName        String
  email           String           @unique
  phone           String?
  role            UserRole         @default(CUSTOMER)
  city            String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  providerProfile ProviderProfile?
  serviceRequests ServiceRequest[] @relation("CustomerRequests")
  quotes          Quote[]          @relation("ProviderQuotes")
  reviews         Review[]         @relation("AuthorReviews")
}

model ProviderProfile {
  id               String           @id @default(cuid())
  userId           String           @unique
  businessName     String
  slug             String           @unique
  description      String?
  city             String
  serviceAreaMiles Int              @default(25)
  isMobile         Boolean          @default(false)
  ratingAverage    Float            @default(0)
  ratingCount      Int              @default(0)
  approvedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  offeredServices  ProviderService[]
  quotes           Quote[]          @relation("ProviderProfileQuotes")
}

model ServiceCategory {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  providers   ProviderService[]
  requests    ServiceRequest[]
}

model ProviderService {
  id                String          @id @default(cuid())
  providerProfileId String
  serviceCategoryId String
  basePriceMin      Decimal?        @db.Decimal(10, 2)
  basePriceMax      Decimal?        @db.Decimal(10, 2)
  providerProfile   ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
  serviceCategory   ServiceCategory @relation(fields: [serviceCategoryId], references: [id], onDelete: Cascade)

  @@unique([providerProfileId, serviceCategoryId])
}

model ServiceRequest {
  id                String          @id @default(cuid())
  customerId        String
  serviceCategoryId String
  title             String
  description       String
  city              String
  address           String?
  preferredDate     DateTime?
  isMobileNeeded    Boolean         @default(false)
  status            RequestStatus   @default(SUBMITTED)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  customer          User            @relation("CustomerRequests", fields: [customerId], references: [id], onDelete: Cascade)
  serviceCategory   ServiceCategory @relation(fields: [serviceCategoryId], references: [id])
  quotes            Quote[]
  reviews           Review[]
}

model Quote {
  id                String          @id @default(cuid())
  requestId         String
  providerUserId    String
  providerProfileId String
  amount            Decimal         @db.Decimal(10, 2)
  estimatedHours    Int?
  notes             String?
  status            QuoteStatus     @default(PENDING)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  request           ServiceRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  providerUser      User            @relation("ProviderQuotes", fields: [providerUserId], references: [id], onDelete: Cascade)
  providerProfile   ProviderProfile @relation("ProviderProfileQuotes", fields: [providerProfileId], references: [id], onDelete: Cascade)
}

model Review {
  id         String         @id @default(cuid())
  requestId  String
  authorId   String
  rating     Int
  comment    String?
  createdAt  DateTime       @default(now())
  request    ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  author     User           @relation("AuthorReviews", fields: [authorId], references: [id], onDelete: Cascade)
}
